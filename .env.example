# Base de datos
# Para Railway MySQL: DATABASE_URL=mysql+pymysql://user:password@host:port/database
DATABASE_URL=

# URL pública de tu app en Railway (sin https)
# Ejemplo: icy-barber-production.up.railway.app
SERVER_NAME=

# Claves de seguridad
SECRET_KEY=tu-clave-secreta-muy-larga-y-aleatoria

# Credenciales admin
ADMIN_PASSWORD=contraseña-fuerte-para-admin

# Bootstrap inicial: true para crear tablas en primer deploy, false después
AUTO_BOOTSTRAP_DB=false

# Alternativo a DATABASE_URL (si prefieres usar variables individuales):
# DB_HOST=localhost
# DB_PORT=3306
# DB_USERNAME=root
# DB_PASSWORD=password
# DB_DATABASE=icy_barber
